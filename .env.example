# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

COMPOSE_PROJECT_NAME=cinema-microservices
ENVIRONMENT=development

# --- MySQL ---
DB_PASSWORD=root
MYSQL_PORT=3306

# --- Service host ports (container internal HTTP: 5000 / gateway: 8080) ---
MOVIE_SERVICE_PORT=5001
SEAT_SERVICE_PORT=5002
CUSTOMER_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
BOOKING_SERVICE_PORT=5005
NOTIFICATION_SERVICE_PORT=5006
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Gateway upstream hostnames (Docker DNS) ---
MOVIE_SERVICE_HOST=movie-service
SEAT_SERVICE_HOST=seat-availability-service
CUSTOMER_SERVICE_HOST=customer-service
PAYMENT_SERVICE_HOST=payment-service
NOTIFICATION_SERVICE_HOST=notification-service
BOOKING_SERVICE_HOST=ticket-booking-service
