# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development

# --- MySQL (Docker + Spring services) ---
# Workbench: connect to localhost + this port. Use 3306 only if Windows MySQL (MySQL80) is stopped; else use 3307.
MYSQL_HOST_PORT=3306
# Inside Docker, Spring services use MYSQL_HOST=mysql and MYSQL_PORT=3306 (set in compose).
MYSQL_PORT=3306
# Root password for the MySQL *container* (Workbench user root uses this when connecting to Docker).
MYSQL_ROOT_PASSWORD=changeme
# For `mvn spring-boot:run` on the host against Docker MySQL: foodorder/foodorder. Compose forces foodorder for containers (root@remote fails).
MYSQL_USER=foodorder
MYSQL_PASSWORD=foodorder

# --- Legacy / other (optional) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=admin
DB_PASSWORD=changeme

# --- Service Ports ---
MENU_SERVICE_PORT=5001
ORDER_SERVICE_PORT=5002
DELIVERY_PAYMENT_SERVICE_PORT=5003
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- API Gateway ---
GATEWAY_SECRET=your-gateway-secret

# --- Menu pricing (demo) ---
# Used by menu-service to compute dynamic pricing (happy hour + size).
MENU_PRICING_ZONE_ID=Asia/Ho_Chi_Minh
MENU_HAPPY_HOUR_START=18:00
MENU_HAPPY_HOUR_END=20:00
MENU_HAPPY_HOUR_DISCOUNT_PERCENT=10

# --- Add more variables as needed for your stack ---
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost:5672
# JWT_SECRET=your-jwt-secret
